.DS_Store
**/.DS_Store

# R history and session files
.Rhistory
.Rapp.history
.RData
.RDataTmp
.Ruserdata

# Example code in package build process
*-Ex.R

# Output files from R CMD build
/*.tar.gz

# Output files from R CMD check
/*.Rcheck/

# RStudio files
.Rproj.user/

# Produced vignettes
vignettes/*.html
vignettes/*.pdf

# OAuth2 token
.httr-oauth

# knitr and R markdown default cache directories
*_cache/
/cache/

# Temporary files created by R markdown
*.utf8.md
*.knit.md

# R Environment Variables
.Renviron

# pkgdown site (built locally)
docs/

# Translation temp files
po/*~

# RStudio Connect folder
rsconnect/

CLAUDE.md

# ── Data update workflow ─────────────────────────────────────────────────────
# data-raw/update_data.R downloads composite.rda/items.rda to a tempfile() and
# writes the result straight into data/ via usethis::use_data(), so nothing
# extra gets left behind here.

# NOTE: data/composite.rda and data/items.rda ARE tracked — they are the
# baked-in package datasets that users receive when they install stigmaR.
